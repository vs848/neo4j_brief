# --- Neo4j (local) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DATABASE=neo4j

# --- Scraping ---
HTTP_TIMEOUT=20
HTTP_USER_AGENT=brandgraph/0.1 (+https://example.local)
MAX_COMPETITORS=8
MAX_PAGES_PER_COMPETITOR=5
REQUEST_DELAY_SECONDS=1.0

# --- Chunking / keywords ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
KEYWORDS_PER_COMPETITOR=25
